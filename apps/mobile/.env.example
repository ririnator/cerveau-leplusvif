# Cerveau Vif - Mobile App Environment Variables
# Copy this file to .env and fill in your keys

# PostHog Analytics (optional - app runs in no-op mode without it)
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com

# RevenueCat In-App Purchases (optional - app runs in stub mode without it)
REVENUECAT_APPLE=
REVENUECAT_ANDROID=

# Notes:
# - The app works without these keys (uses safe stubs)
# - PostHog will log to console in stub mode
# - RevenueCat will always return false for purchases in stub mode
# - DO NOT commit .env with real keys to git
