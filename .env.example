# Cerveau Vif - Environment Variables Template
# Copy this file to .env and fill in your API keys

# PostHog Analytics (optional for V1)
POSTHOG_API_KEY=your_posthog_api_key_here

# RevenueCat Payments (optional for V1)
REVENUECAT_API_KEY=your_revenuecat_api_key_here

# Supabase (Phase 3)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Notes:
# - App works without these keys (uses safe stubs)
# - PostHog logs to console in stub mode
# - RevenueCat always returns false in stub mode
# - Supabase not used in V1
